{
  "name": "shrekdb",
  "version": "0.1.0",
  "description": "shrekDB — a local-first time-series core in TypeScript: binary .shrekdb storage with O(1) random access and LTTB downsampling.",
  "author": "Vivaan Dudeja",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "shrekdb": "dist/cli.js"
  },
  "files": [
    "dist",
    "public"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx examples/demo.ts",
    "cli": "tsx src/cli.ts"
  },
  "keywords": [
    "time-series",
    "lttb",
    "downsampling",
    "binary-format",
    "shrekdb"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
